# Copiar a ~/.config/aegis/config.env o apuntar AEGIS_CONFIG_FILE a otra ruta.

# Base persistente donde viven source/, source.7z, source.7z.sha256 y backups/
AEGIS_SECRETS_PATH="$HOME/projects/security/secrets"

# Directorio de estado para last_source_root y otros metadatos locales
AEGIS_STATE_DIR="$HOME/.config/aegis"

# Archivo JSON con app_key, app_secret y refresh_token de Dropbox
AEGIS_DROPBOX_CREDENTIALS_FILE="$HOME/.config/aegis/dropbox.json"
